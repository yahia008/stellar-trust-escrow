DATABASE_URL=postgresql://postgres:password@localhost:5432/stellar_trust_escrow

STELLAR_NETWORK=testnet
CONTRACT_ADDRESS=
SOROBAN_RPC_URL=https://soroban-testnet.stellar.org
STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org
STELLAR_NETWORK_PASSPHRASE=Test SDF Network ; September 2015

PORT=4000
NODE_ENV=development

EMAIL_PROVIDER=console
EMAIL_FROM=no-reply@example.com
EMAIL_FROM_NAME=Stellar Trust Escrow
EMAIL_BASE_URL=http://localhost:4000
EMAIL_RATE_LIMIT_PER_MINUTE=20
EMAIL_MAX_RETRIES=3
EMAIL_RETRY_BASE_DELAY_MS=15000
EMAIL_QUEUE_POLL_INTERVAL_MS=5000
EMAIL_UNSUBSCRIBE_SECRET=change_this_secret
SENDGRID_API_KEY=

JWT_SECRET=change_this_in_production
# Admin API key — required for all /api/admin/* endpoints (see Issue #23)
# Generate a strong random secret: openssl rand -hex 32
ADMIN_API_KEY=change_this_to_a_strong_random_secret

# ── Platform ───────────────────────────────────────────────────────────────────
PLATFORM_FEE_PERCENT=1.5
ALLOWED_ORIGINS=http://localhost:3000

# Redis (optional — falls back to in-memory cache if unset)
REDIS_URL=redis://localhost:6379

INDEXER_POLL_INTERVAL_MS=5000
INDEXER_START_LEDGER=0
# The deployed escrow contract address (required for event indexing)
ESCROW_CONTRACT_ID=

# ── Sentry Error Tracking ──────────────────────────────────────────────────────
# Get your DSN from https://sentry.io → Project Settings → Client Keys
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
# Set to a git SHA or semver tag for release tracking
SENTRY_RELEASE=
# 0.0–1.0 — fraction of transactions to trace (default: 0.1 in prod, 1.0 in dev)
SENTRY_TRACES_SAMPLE_RATE=

# The deployed escrow contract address (required for event indexing)
ESCROW_CONTRACT_ID=

# KYC — Sumsub (https://developers.sumsub.com)
SUMSUB_APP_TOKEN=
SUMSUB_SECRET_KEY=
SUMSUB_BASE_URL=https://api.sumsub.com
SUMSUB_LEVEL_NAME=basic-kyc-level

# Payments — Stripe (https://stripe.com/docs/keys)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
FRONTEND_URL=http://localhost:3000
# USDC issuer on Stellar (mainnet: GA5ZSEJYB37JRC5AVCIA5MOP4RHTM335X2KGX3IHOJAPP5RE34K4KZVN)
USDC_ISSUER=

# ── Performance Monitoring ─────────────────────────────────────────────────────
SLOW_REQUEST_THRESHOLD_MS=500
SLOW_QUERY_THRESHOLD_MS=200
METRICS_TOKEN=
