"lint-staged": {
  "*.{js,ts,tsx,json,md}": [
    "prettier --write",
    "git add"
  ],
  "*.{js,ts,tsx}": [
    "eslint --fix",
    "git add"
  ],
  "*.sol": [
    "solhint --fix",
    "prettier --write",
    "git add"
  ],
  "*.{css,scss,html}": [
    "prettier --write",
    "git add"
  ],
  "*.rs": [
    "rustfmt",
    "git add"
  ]
}
